# Copy this file to `.env` for local devcontainer, notebook, and tool runs.
# Keep credentials and machine-specific overrides only in `.env`.

UV_PROJECT_ENVIRONMENT=.venv
UV_LINK_MODE=copy

AMPERE_UC_CATALOG=
AMPERE_UC_SSH_JUMP_HOST=
AMPERE_UC_SSH_CLUSTER_HOST=
AMPERE_UC_K8S_NAMESPACE=unity-catalog
AMPERE_UC_SERVICE_NAME=unity-catalog-unitycatalog-server
AMPERE_UC_SERVICE_PORT=8080

AMPERE_MINIO_ENDPOINT=https://s3.minio.local
AMPERE_MINIO_REGION=us-east-1
AMPERE_MINIO_SSL_VERIFY=false
AMPERE_MINIO_ACCESS_KEY=
AMPERE_MINIO_SECRET_KEY=

AMPERE_POSTGRES_HOST=postgres.local
AMPERE_POSTGRES_PORT=5432
AMPERE_POSTGRES_DB=ampere_db
AMPERE_POSTGRES_USER=postgres
AMPERE_POSTGRES_PASSWORD=

AMPERE_SPARK_REMOTE=sc://sparkconnect.local:443/;use_ssl=true
AMPERE_GRPC_SSL_ROOTS_FILE_PATH=
